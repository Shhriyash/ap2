AGENT_SERVICE_NAME=agent-service
AGENT_HOST=0.0.0.0
AGENT_PORT=8000
AGENT_DEBUG=true

# Groq (primary)
GROQ_API_KEY=replace_me
GROQ_MODEL=openai/gpt-oss-120b
GROQ_SLOT_MODEL=openai/gpt-oss-120b
# Voice STT fallback key expected by fastrtc_real.py
GROQ_API_KEY2=replace_me

# Voice TTS (primary provider)
DEEPGRAM_API_KEY=replace_me
DEEPGRAM_TTS_MODEL=aura-2-orion-en
DEEPGRAM_TTS_ENCODING=linear16
DEEPGRAM_TTS_CONTAINER=wav
DEEPGRAM_TTS_SAMPLE_RATE=24000

# OpenRouter (fallback)
OPENROUTER_API_KEY=replace_me
OPENROUTER_MODEL=openai/gpt-4.1-mini
OPENROUTER_SLOT_MODEL=openai/gpt-4.1-mini

# Supabase auth (required for CLI login)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=replace_me
# Optional but recommended for onboarding signup auto-create with confirmed users
SUPABASE_SERVICE_ROLE_KEY=

# Internal gateway target
GATEWAY_BASE_URL=http://localhost:8100
GATEWAY_TIMEOUT_SECONDS=20
INTERNAL_SERVICE_TOKEN=replace_me_internal_token

# Auth and runtime settings
DEFAULT_CURRENCY=AED
AGENT_SESSION_TTL_MINUTES=240
MAX_PIN_ATTEMPTS=3
MAX_OTP_ATTEMPTS=3

# ============================================================
# Gateway Service Settings (Unified Env)
# ============================================================
GATEWAY_SERVICE_NAME=gateway-service
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8100
GATEWAY_DEBUG=true

# Supabase Postgres DSN (transaction pooler or direct DB URL)
# Example:
# postgresql+psycopg://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
SUPABASE_DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/agent_payments
