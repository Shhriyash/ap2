GATEWAY_SERVICE_NAME=gateway-service
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8100
GATEWAY_DEBUG=true

# Supabase Postgres URL (transaction pooler or direct DB URL)
DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/agent_payments

# Provider mode:
# dummy    -> local DB debit/credit simulation
# external -> relay to real payment API with minimal code changes
PAYMENT_PROVIDER_MODE=dummy

# Used only when PAYMENT_PROVIDER_MODE=external
EXTERNAL_PAYMENT_BASE_URL=https://api.example-payments.com
EXTERNAL_PAYMENT_API_KEY=replace_me
EXTERNAL_PAYMENT_TIMEOUT_SECONDS=20

DEFAULT_CURRENCY=AED
